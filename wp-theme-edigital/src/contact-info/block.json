{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "edigital/contact-info",
	"version": "1.1.0",
	"title": "E-Digital — Carte Contact (sidebar contact)",
	"category": "edigital",
	"icon": "phone",
	"description": "Carte sombre regroupant tel, email, adresses, horaires et réseaux sociaux pour la sidebar contact.",
	"keywords": ["contact", "téléphone", "email", "adresse"],
	"textdomain": "edigital",
	"supports": {
		"html": false,
		"reusable": true
	},
	"attributes": {
		"titre":          { "type": "string", "default": "Parlons de votre projet" },
		"telLabel":       { "type": "string", "default": "Appelez-nous" },
		"telValue":       { "type": "string", "default": "" },
		"emailLabel":     { "type": "string", "default": "Écrivez-nous" },
		"emailValue":     { "type": "string", "default": "" },
		"adresse1Label":  { "type": "string", "default": "" },
		"adresse1Value":  { "type": "string", "default": "" },
		"adresse2Label":  { "type": "string", "default": "" },
		"adresse2Value":  { "type": "string", "default": "" },
		"horairesLabel":  { "type": "string", "default": "Horaires" },
		"horairesValue":  { "type": "string", "default": "" },
		"facebookUrl":    { "type": "string", "default": "" },
		"linkedinUrl":    { "type": "string", "default": "" }
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
