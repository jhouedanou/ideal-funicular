{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "edigital/pricing",
	"version": "1.0.0",
	"title": "E-Digital — Section Tarifs",
	"category": "edigital",
	"icon": "money-alt",
	"description": "Section tarifs avec cartes (titre, prix, points, CTA) et bandeau additionnel.",
	"keywords": ["pricing", "tarifs", "prix"],
	"textdomain": "edigital",
	"supports": {
		"html": false,
		"reusable": true
	},
	"attributes": {
		"titre": {
			"type": "string",
			"default": "NOS TARIFS"
		},
		"ancre": {
			"type": "string",
			"default": "tarifs"
		},
		"extras": {
			"type": "array",
			"default": [],
			"items": { "type": "object" }
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
