{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "edigital/expertise-card",
	"version": "1.0.0",
	"title": "E-Digital — Carte expertise",
	"category": "edigital",
	"icon": "format-image",
	"parent": ["edigital/expertise-grid"],
	"description": "Carte d'expertise (image + titre + catégorie + lien).",
	"keywords": ["expertise", "carte", "service"],
	"textdomain": "edigital",
	"supports": {
		"html": false,
		"reusable": false,
		"inserter": true
	},
	"attributes": {
		"titre": {
			"type": "string",
			"default": "Conception de site vitrine"
		},
		"categorie": {
			"type": "string",
			"default": "Web Design"
		},
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"lien": {
			"type": "string",
			"default": "/projet/"
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
